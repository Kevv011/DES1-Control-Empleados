@model DES1_Control_Empleados.Models.Employee

@{
    ViewData["Title"] = "Nuevo Empleado";
}

<div class="row justify-content-center my-4">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-0 pt-4 pb-0 text-center">
                <h2 class="text-primary fw-bold mb-2">➕ Nuevo Empleado</h2>
                <p class="text-muted">Ingresa los detalles del empleado a continuación</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-md-6 form-group">
                            <label asp-for="Code" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="Code" class="form-control rounded-3" placeholder="Ej. EMP-001" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 form-group">
                            <label asp-for="Name" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="Name" class="form-control rounded-3" placeholder="Nombre completo" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 form-group">
                            <label asp-for="BirthDate" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="BirthDate" class="form-control rounded-3" type="date" />
                            <span asp-validation-for="BirthDate" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 form-group">
                            <label asp-for="HireDate" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="HireDate" class="form-control rounded-3" type="date" />
                            <span asp-validation-for="HireDate" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 form-group">
                            <label asp-for="Salary" class="form-label fw-semibold text-secondary"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-secondary rounded-start-3">$</span>
                                <input asp-for="Salary" class="form-control rounded-end-3" type="number" step="0.01" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Salary" class="text-danger small"></span>
                        </div>

                        <div class="col-12 form-group">
                            <label asp-for="Description" class="form-label fw-semibold text-secondary"></label>
                            <textarea asp-for="Description" class="form-control rounded-3" rows="3" placeholder="Descripción o notas adicionales"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr class="my-4 text-muted" />

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-3 px-4 d-flex align-items-center gap-2">
                            <span>⬅️</span> Regresar
                        </a>
                        <button type="submit" class="btn btn-primary rounded-3 px-5 d-flex align-items-center gap-2 shadow-sm">
                            <span>💾</span> Guardar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
