@model DES1_Control_Empleados.Models.Department

@{
    ViewData["Title"] = "Nuevo Departamento";
}

<div class="row justify-content-center my-4">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-0 pt-4 pb-0 text-center">
                <h2 class="text-primary fw-bold mb-2">Nuevo Departamento</h2>
                <p class="text-muted">Ingresa los detalles del departamento a continuación</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-md-6 form-group">
                            <label asp-for="Code" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="Code" class="form-control rounded-3" placeholder="Ej. DEP-01" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 form-group">
                            <label asp-for="Name" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="Name" class="form-control rounded-3" placeholder="Nombre de departamento" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-12 form-group">
                            <label asp-for="Description" class="form-label fw-semibold text-secondary"></label>
                            <textarea asp-for="Description" class="form-control rounded-3" rows="3" placeholder="Descripción o detalles adicionales"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr class="my-4 text-muted" />

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-3 px-4 d-flex align-items-center gap-2">
                            Regresar
                        </a>
                        <button type="submit" class="btn btn-primary rounded-3 px-5 d-flex align-items-center gap-2 shadow-sm">
                            Guardar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
