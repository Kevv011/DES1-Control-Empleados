@model IEnumerable<DES1_Control_Empleados.Models.Department>

@{
    ViewData["Title"] = "Departamentos";
}

<div class="card shadow-sm border-0 my-4">
    <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center pt-4 pb-2">
        <h2 class="mb-0 text-primary fw-bold">Departamentos</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm d-flex align-items-center gap-2">
           Nuevo Departamento
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="text-secondary fw-semibold" style="width: 15%">
                            @Html.DisplayNameFor(model => model.Code)
                        </th>
                        <th class="text-secondary fw-semibold" style="width: 30%">
                            @Html.DisplayNameFor(model => model.Name)
                        </th>
                        <th class="text-secondary fw-semibold">
                            @Html.DisplayNameFor(model => model.Description)
                        </th>
                        <th class="text-end text-secondary fw-semibold" style="width: 15%">Acciones</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
            @foreach (var item in Model) {
                    <tr>
                        <td>
                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill">
                                @Html.DisplayFor(model => item.Code)
                            </span>
                        </td>
                        <td class="fw-medium text-dark">
                            @Html.DisplayFor(model => item.Name)
                        </td>
                        <td class="text-muted text-truncate" style="max-width: 300px;">
                            @Html.DisplayFor(model => item.Description)
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm" role="group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Editar">✏️</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="Detalles">📄</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Eliminar">🗑️</a>
                            </div>
                        </td>
                    </tr>
            }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <p class="mt-3 mb-0">No hay departamentos registrados aún.</p>
            </div>
        }
    </div>
</div>
